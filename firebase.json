<script type="module">
  // استيراد مكتبات Firebase (إصدار 9)
  import { initializeApp } from "https://www.gstatic.com/firebasejs/9.6.1/firebase-app.js";
  import { 
    getDatabase, ref, set, push, update, remove, onValue 
  } from "https://www.gstatic.com/firebasejs/9.6.1/firebase-database.js";

  // إعداداتك أنت:
  const firebaseConfig = {
    apiKey: "AIzaSyBxPO6RKsQ1Cq-mqlCpFTrCuIyxnYdB37U",
    authDomain: "studentsystem-c1ab1.firebaseapp.com",
    databaseURL: "https://studentsystem-c1ab1-default-rtdb.firebaseio.com",
    projectId: "studentsystem-c1ab1",
    storageBucket: "studentsystem-c1ab1.firebasestorage.app",
    messagingSenderId: "112215023848",
    appId: "1:112215023848:web:0adba326a527ee7e37e95d"
  };

  // تشغيل Firebase
  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  // ---------------------------
  //  وظائف جاهزة للكتابة والقراءة
  // ---------------------------

  // 🔵 إضافة سجل جديد
  window.addStudent = function (name, group) {
    const studentsRef = ref(db, "students");
    const newStudent = push(studentsRef);

    return set(newStudent, {
      name: name,
      group: group,
      time: Date.now()
    });
  };

  // 🟢 قراءة كل السجلات
  window.loadStudents = function (callback) {
    const studentsRef = ref(db, "students");

    onValue(studentsRef, snapshot => {
      const data = snapshot.val();
      callback(data);
    });
  };

  // 🟡 تحديث سجل
  window.updateStudent = function (id, data) {
    return update(ref(db, "students/" + id), data);
  };

  // 🔴 حذف سجل
  window.deleteStudent = function (id) {
    return remove(ref(db, "students/" + id));
  };

</script>